# Environment variables for local React Native / Expo development
# Copy this file to a new file named '.env' in this directory and update the values.

# Set this to your deployed Railway backend URL to test the local Expo Go application against your live API.
# Note: include the '/api' suffix (e.g., https://your-backend-api.up.railway.app/api)
EXPO_PUBLIC_API_URL=https://your-backend-api.up.railway.app/api
