datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Customer {
  id          String    @id @default(uuid())
  phoneNumber String    @unique @map("phone_number")
  name        String
  email       String?
  createdAt   DateTime  @default(now()) @map("created_at")
  lastVisit   DateTime? @map("last_visit")
  totalVisits Int       @default(1) @map("total_visits")
  tokens      Token[]

  @@map("customers")
}

model PlaceTypeConfig {
  id                   String    @id @default(uuid())
  name                 String    @unique
  ratePerPerson        Decimal   @db.Decimal(10, 2) @map("rate_per_person")
  baseTimeMinutes      Int       @map("base_time_minutes")
  redemptionsPerPerson Int       @default(2) @map("redemptions_per_person")
  isActive             Boolean   @default(true) @map("is_active")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime? @updatedAt @map("updated_at")
  tables               Table[]
  tokens               Token[]
  rateLogs             RateLog[]

  @@map("place_types")
}

model Table {
  id             String               @id @default(uuid())
  tableNumber    String               @map("table_number")
  placeTypeId    String               @map("place_type_id")
  placeType      PlaceTypeConfig      @relation(fields: [placeTypeId], references: [id])
  capacity       Int                  @default(2)
  status         String               @default("available") // available, occupied, reserved, maintenance
  currentTokenId String?              @map("current_token_id")
  occupiedSince  DateTime?            @map("occupied_since")
  lastAssignedAt DateTime?            @map("last_assigned_at")
  isActive       Boolean              @default(true) @map("is_active")
  maintenanceStart DateTime?            @map("maintenance_start")
  maintenanceEnd   DateTime?            @map("maintenance_end")
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime?            @updatedAt @map("updated_at")
  tokens         Token[]              @relation("TableTokens")
  occupancyLogs  TableOccupancyLog[]

  @@unique([tableNumber, placeTypeId])
  @@map("tables")
}

model Token {
  id                      String              @id @default(uuid())
  tokenNumber             String              @unique @map("token_number")
  customerId              String              @map("customer_id")
  customer                Customer            @relation(fields: [customerId], references: [id])
  personsCount            Int                 @map("persons_count")
  placeTypeId             String              @map("place_type_id")
  placeType               PlaceTypeConfig     @relation(fields: [placeTypeId], references: [id])
  tableId                 String?             @map("table_id")
  table                   Table?              @relation("TableTokens", fields: [tableId], references: [id])
  amountPaid              Decimal             @db.Decimal(10, 2) @map("amount_paid")
  paymentVerified         Boolean             @default(false) @map("payment_verified")
  startTime               DateTime            @default(now()) @map("start_time")
  endTime                 DateTime            @map("end_time")
  totalRedemptionsAllowed Int                 @map("total_redemptions_allowed")
  redemptionsUsed         Int                 @default(0) @map("redemptions_used")
  status                  TokenStatus         @default(ACTIVE) @map("status")
  issuedBy                String              @map("issued_by")
  creator                 User                @relation("TokenIssuedBy", fields: [issuedBy], references: [id])
  issuedAt                DateTime            @default(now()) @map("issued_at")
  closedAt                DateTime?           @map("closed_at")
  closedBy                String?             @map("closed_by")
  closeReason             CloseReason?        @map("close_reason")
  closer                  User?               @relation("TokenClosedBy", fields: [closedBy], references: [id])
  card                    Card?               @relation("CardCurrentToken")
  deliveryMode            String              @default("NFC_CARD") @map("delivery_mode") // NFC_CARD, EMAIL_QR
  emailSent               Boolean             @default(false) @map("email_sent")
  emailSentAt             DateTime?           @map("email_sent_at")
  emailDeliveryStatus     String?             @map("email_delivery_status") // PENDING, SENT, FAILED
  redemptions             Redemption[]
  extensions              TokenExtension[]
  tableOccupancyLogs      TableOccupancyLog[]

  // Audit and lifecycle fields
  activatedAt             DateTime?           @map("activated_at")
  activatedBy             String?             @map("activated_by")
  activationMethod        ActivationMethod?   @map("activation_method")
  cancelledAt             DateTime?           @map("cancelled_at")
  cancelledBy             String?             @map("cancelled_by")
  cancelReason            CancelReason?       @map("cancel_reason")
  paymentConfirmedAt      DateTime?           @map("payment_confirmed_at")
  paymentConfirmedBy      String?             @map("payment_confirmed_by")

  @@map("tokens")
}

model Redemption {
  id                 String   @id @default(uuid())
  tokenId            String   @map("token_id")
  token              Token    @relation(fields: [tokenId], references: [id], onDelete: Cascade)
  redemptionSequence Int      @map("redemption_sequence")
  redeemedAt         DateTime @default(now()) @map("redeemed_at")
  bartenderId        String   @map("bartender_id")
  bartender          User     @relation(fields: [bartenderId], references: [id])
  notes              String?

  @@unique([tokenId, redemptionSequence])
  @@map("redemptions")
}

model Card {
  id             String    @id @default(uuid())
  nfcUid         String    @unique @map("nfc_uid")
  status         String    @default("available") @map("status") // available, assigned, lost, damaged
  assignedAt     DateTime? @map("assigned_at")
  returnedAt     DateTime? @map("returned_at")
  writeCycles    Int       @default(0) @map("write_cycles")
  lastWrittenAt  DateTime? @map("last_written_at")
  currentTokenId String?   @unique @map("current_token_id")
  currentToken   Token?    @relation("CardCurrentToken", fields: [currentTokenId], references: [id])

  @@map("cards")
}

model TokenExtension {
  id               String   @id @default(uuid())
  tokenId          String   @map("token_id")
  token            Token    @relation(fields: [tokenId], references: [id])
  extraMinutes     Int      @map("extra_minutes")
  additionalAmount Decimal  @db.Decimal(10, 2) @map("additional_amount")
  approvedBy       String   @map("approved_by")
  approver         User     @relation(fields: [approvedBy], references: [id])
  extendedAt       DateTime @default(now()) @map("extended_at")
  newEndTime       DateTime @map("new_end_time")

  @@map("token_extensions")
}

model TableOccupancyLog {
  id              String    @id @default(uuid())
  tableId         String    @map("table_id")
  table           Table     @relation(fields: [tableId], references: [id])
  tokenId         String    @map("token_id")
  token           Token     @relation(fields: [tokenId], references: [id])
  occupiedAt      DateTime  @default(now()) @map("occupied_at")
  vacatedAt       DateTime? @map("vacated_at")
  durationMinutes Int?      @map("duration_minutes") // generated/computed dynamically or stored on checkout/vacate

  @@map("table_occupancy_logs")
}

model User {
  id               String           @id @default(uuid())
  username         String           @unique
  passwordHash     String           @map("password_hash")
  fullName         String           @map("full_name")
  roleId           String           @map("role_id")
  role             Role             @relation(fields: [roleId], references: [id])
  isActive         Boolean          @default(true) @map("is_active")
  lastLogin        DateTime?        @map("last_login")
  createdAt        DateTime         @default(now()) @map("created_at")
  redemptions      Redemption[]
  tokensIssued     Token[]          @relation("TokenIssuedBy")
  tokensClosed     Token[]          @relation("TokenClosedBy")
  tokenExtensions  TokenExtension[]
  rateCardChanges  RateLog[]
  sessions         StaffSession[]

  @@map("users")
}

model Role {
  id          String @id @default(uuid())
  name        String @unique // admin, receptionist, bartender, manager
  permissions Json   @default("{}")
  users       User[]

  @@map("roles")
}

model RateLog {
  id           String          @id @default(uuid())
  placeTypeId  String          @map("place_type_id")
  placeType    PlaceTypeConfig @relation(fields: [placeTypeId], references: [id])
  oldRate      Decimal         @db.Decimal(10, 2) @map("old_rate")
  newRate      Decimal         @db.Decimal(10, 2) @map("new_rate")
  changedBy    String          @map("changed_by")
  changer      User            @relation(fields: [changedBy], references: [id])
  changedAt    DateTime        @default(now()) @map("changed_at")

  @@map("rate_logs")
}

model SyncLog {
  id             String    @id @default(uuid())
  operationId    String    @unique @map("operation_id")
  deviceId       String    @map("device_id")
  operationType  String    @map("operation_type")
  payload        Json
  status         String    // SUCCESS, CONFLICT, ERROR
  conflictReason String?   @map("conflict_reason")
  createdAt      DateTime  @default(now()) @map("created_at")
  processedAt    DateTime? @map("processed_at")

  @@map("sync_logs")
}

model RoleChangeLog {
  id           String   @id @default(uuid())
  targetUserId String   @map("target_user_id")
  changedBy    String   @map("changed_by")
  oldRole      String   @map("old_role")
  newRole      String   @map("new_role")
  changedAt    DateTime @default(now()) @map("changed_at")

  @@map("role_change_logs")
}

model SystemConfig {
  id          String   @id @default(uuid())
  configKey   String   @unique @map("config_key")
  configValue String   @map("config_value")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")
  updatedBy   String?  @map("updated_by")

  @@map("system_configs")
}

model StaffSession {
  id        String   @id @default(uuid()) @map("id")
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("staff_sessions")
}

enum CloseReason {
  MANUAL
  QR_SCAN
  CHECKOUT
  SESSION_EXPIRED
}

enum TokenStatus {
  PENDING_PAYMENT
  ACTIVE
  CLOSED
  CANCELLED
  EXPIRED
  EXTENDED
}

enum ActivationMethod {
  EMAIL_QR
  NFC
}

enum CancelReason {
  USER_CANCELLED
  PAYMENT_CANCELLED
  DUPLICATE_CHECKIN
  SESSION_RESTARTED
  OTHER
}
